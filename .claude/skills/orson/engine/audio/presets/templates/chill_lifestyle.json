{
  "template_id": "chill_lifestyle",
  "display_name": "Chill / Lifestyle",
  "description": "Relaxed, warm vibes for wellness, travel, coffee brands, and lifestyle content",
  "use_cases": ["wellness", "travel", "coffee", "fashion", "lifestyle", "vlog"],

  "parameters": {
    "duration": { "type": "enum", "values": ["30s", "60s"], "default": "30s" },
    "energy": { "type": "range", "min": 0.2, "max": 0.7, "default": 0.45 },
    "voiceover": { "type": "bool", "default": true }
  },

  "base_style": "lo-fi",

  "duration_adaptations": {
    "30s": {
      "arc_strategy": "compressed",
      "impact_intensity": 0.6,
      "phases": { "impact": [0, 0.08], "build": [0.08, 0.5], "climax": [0.5, 0.83], "resolve": [0.83, 1.0] }
    },
    "60s": {
      "arc_strategy": "full",
      "impact_intensity": 0.5,
      "phases": { "impact": [0, 0.04], "intro": [0.04, 0.25], "build": [0.25, 0.5], "climax": [0.5, 0.83], "resolve": [0.83, 1.0] }
    }
  },

  "energy_scaling": {
    "affects": ["velocity_multiplier", "density", "filter_brightness"],
    "formula": {
      "velocity_multiplier": "0.4 + (energy * 0.4)",
      "density": "energy < 0.4 ? 'sparse' : 'balanced'",
      "filter_brightness": "800 + (energy * 1500)"
    }
  },

  "voiceover_adaptation": {
    "if_true": { "apply_mode": "voiceover_bed", "mid_gain_reduction": 0.4 }
  },

  "track_hints": {
    "bpm": 78,
    "key": "Eb major"
  }
}
