{
  "template_id": "epic_trailer",
  "display_name": "Epic Trailer",
  "description": "Cinematic orchestral intensity for film trailers, game launches, and epic product reveals",
  "use_cases": ["film trailer", "game trailer", "product launch", "reveal", "announcement"],

  "parameters": {
    "duration": { "type": "enum", "values": ["15s", "30s", "60s"], "default": "30s" },
    "energy": { "type": "range", "min": 0.5, "max": 1.0, "default": 0.85 },
    "voiceover": { "type": "bool", "default": false }
  },

  "base_style": "cinematic",

  "duration_adaptations": {
    "15s": {
      "arc_strategy": "no_arc",
      "impact_intensity": 1.0,
      "phases": { "impact": [0, 0.17], "climax": [0.17, 0.83], "resolve": [0.83, 1.0] }
    },
    "30s": {
      "arc_strategy": "compressed",
      "impact_intensity": 0.95,
      "phases": { "impact": [0, 0.08], "build": [0.08, 0.5], "climax": [0.5, 0.83], "resolve": [0.83, 1.0] }
    },
    "60s": {
      "arc_strategy": "full",
      "impact_intensity": 0.85,
      "phases": { "impact": [0, 0.04], "intro": [0.04, 0.25], "build": [0.25, 0.5], "climax": [0.5, 0.83], "resolve": [0.83, 1.0] }
    }
  },

  "energy_scaling": {
    "affects": ["velocity_multiplier", "density", "filter_brightness"],
    "formula": {
      "velocity_multiplier": "0.6 + (energy * 0.4)",
      "density": "energy < 0.6 ? 'balanced' : 'dense'",
      "filter_brightness": "1500 + (energy * 2500)"
    }
  },

  "voiceover_adaptation": {
    "if_true": { "apply_mode": "voiceover_bed", "mid_gain_reduction": 0.35 }
  },

  "track_hints": {
    "bpm": 80,
    "key": "D minor"
  }
}
