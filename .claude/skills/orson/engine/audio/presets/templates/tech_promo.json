{
  "template_id": "tech_promo",
  "display_name": "Tech / Startup Promo",
  "description": "Clean, optimistic electronic for SaaS, apps, AI demos, and tech product launches",
  "use_cases": ["SaaS", "startup", "app", "AI demo", "product launch", "explainer"],

  "parameters": {
    "duration": { "type": "enum", "values": ["15s", "30s", "60s"], "default": "30s" },
    "energy": { "type": "range", "min": 0.3, "max": 1.0, "default": 0.7 },
    "voiceover": { "type": "bool", "default": false }
  },

  "base_style": "electronic",

  "duration_adaptations": {
    "15s": {
      "arc_strategy": "no_arc",
      "impact_intensity": 1.0,
      "phases": { "impact": [0, 0.25], "climax": [0.25, 0.88], "resolve": [0.88, 1.0] }
    },
    "30s": {
      "arc_strategy": "compressed",
      "impact_intensity": 0.9,
      "phases": { "impact": [0, 0.13], "build": [0.13, 0.5], "climax": [0.5, 0.88], "resolve": [0.88, 1.0] }
    },
    "60s": {
      "arc_strategy": "full",
      "impact_intensity": 0.8,
      "phases": { "impact": [0, 0.06], "intro": [0.06, 0.25], "build": [0.25, 0.5], "climax": [0.5, 0.88], "resolve": [0.88, 1.0] }
    }
  },

  "energy_scaling": {
    "affects": ["velocity_multiplier", "density", "filter_brightness"],
    "formula": {
      "velocity_multiplier": "0.5 + (energy * 0.5)",
      "density": "energy < 0.5 ? 'sparse' : energy < 0.8 ? 'balanced' : 'dense'",
      "filter_brightness": "1000 + (energy * 3000)"
    }
  },

  "voiceover_adaptation": {
    "if_true": { "apply_mode": "voiceover_bed", "mid_gain_reduction": 0.3 }
  },

  "track_hints": {
    "bpm": 120,
    "key": "A minor"
  }
}
