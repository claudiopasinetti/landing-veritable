{
  "version": "4.0.0",
  "last_updated": "2026-02-15",
  "description": "Master mapping: context → style, mode → style, style → SFX family. V4: Trimmed to styles with actual tracks in audio-library.json. Styles without tracks removed — restore when tracks are sourced.",

  "styles": {
    "corporate": {
      "bpm": [80, 100], "energy": "low-medium",
      "contexts": ["SaaS", "B2B", "enterprise", "fintech"],
      "default_sfx": "clean",
      "feature_profile": { "arousal": "low", "valence": "bright", "priority": 1 }
    },
    "cinematic": {
      "bpm": [60, 90], "energy": "medium-high",
      "contexts": ["product-launch", "brand-story", "trailer"],
      "default_sfx": "cinematic",
      "feature_profile": { "arousal": "medium", "valence": "neutral", "priority": 1 }
    },
    "electronic": {
      "bpm": [110, 128], "energy": "medium-high",
      "contexts": ["startup", "tech", "app", "dev-tools"],
      "default_sfx": "digital",
      "feature_profile": { "arousal": "high", "valence": "neutral", "priority": 1 }
    },
    "lo-fi": {
      "bpm": [70, 85], "energy": "low",
      "contexts": ["lifestyle", "edu", "blog", "podcast"],
      "default_sfx": "organic",
      "feature_profile": { "arousal": "low", "valence": "bright", "priority": 2 }
    },
    "ambient": {
      "bpm": [60, 80], "energy": "very-low",
      "contexts": ["luxury", "minimal", "portfolio", "wellness"],
      "default_sfx": "clean",
      "feature_profile": { "arousal": "low", "valence": "neutral", "priority": 1 }
    },
    "upbeat": {
      "bpm": [120, 140], "energy": "high",
      "contexts": ["social-media", "promo", "gaming", "retail"],
      "default_sfx": "hyper",
      "feature_profile": { "arousal": "high", "valence": "bright", "priority": 1 }
    }
  },

  "sfx_families": {
    "clean":     { "description": "Click puliti, chime cristallini, whoosh morbidi", "associated_styles": ["corporate", "ambient"] },
    "digital":   { "description": "Blip, glitch, byte sound, keystroke", "associated_styles": ["electronic"] },
    "organic":   { "description": "Percussioni legno, page turn, spring, tap", "associated_styles": ["lo-fi"] },
    "cinematic": { "description": "Impact profondi, riser orchestrali, swell, brass stab", "associated_styles": ["cinematic"] },
    "hyper":     { "description": "Impact massivi, laser, stinger aggressivi, reverse cymbal", "associated_styles": ["upbeat"] }
  },

  "mode_mapping": {
    "safe": {
      "soundtrack_styles": ["corporate", "ambient", "lo-fi"],
      "sfx_family": "clean",
      "sfx_alt": "organic"
    },
    "chaos": {
      "soundtrack_styles": ["electronic", "upbeat"],
      "sfx_family": "digital",
      "sfx_alt": "hyper"
    },
    "hybrid": {
      "soundtrack_styles": ["corporate", "cinematic", "electronic"],
      "sfx_family": "clean",
      "sfx_surprise": ["cinematic", "hyper"]
    },
    "cocomelon": {
      "soundtrack_styles": ["upbeat", "electronic"],
      "sfx_family": "hyper",
      "sfx_density": "maximum",
      "pattern_interrupt_interval_sec": 3.5
    }
  },

  "style_selection_algorithm": {
    "description": "Deterministic style selection using feature vector from video context",
    "steps": [
      "1. Determine mode from video config",
      "2. Filter styles by mode_mapping[mode].soundtrack_styles",
      "3. Match context tags to style.contexts",
      "4. Match energy level to style.energy",
      "5. If multiple matches, pick lowest priority number",
      "6. Fallback: corporate (safe/hybrid) or electronic (chaos) or upbeat (cocomelon)"
    ]
  }
}
